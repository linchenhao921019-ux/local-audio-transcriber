#!/usr/bin/env bash
set -euo pipefail

TOOL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="${CODEX_AUDIO_TRANSCRIBE_VENV:-$HOME/.codex/venvs/audio-transcriber}"

if [[ ! -x "$VENV_DIR/bin/python" ]]; then
  echo "Missing virtual environment. Run: $TOOL_DIR/install_mac_mini.sh" >&2
  exit 1
fi

exec "$VENV_DIR/bin/python" "$TOOL_DIR/transcribe_funasr_chunks.py" "$@"
